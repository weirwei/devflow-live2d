{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DPartner",
  "version": "0.3.0",
  "identifier": "com.devflow.live2d",
  "build": {
    "beforeBuildCommand": "npm run prepare:tauri-web",
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../build-resources/tauri-web"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": []
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "externalBin": [
      "../build-resources/bundle/devflow-protocol-go/bin/devflow-protocol"
    ],
    "resources": {
      "../build-resources/bundle/devflow-protocol-go/claude-plugin": "bundle/devflow-protocol-go/claude-plugin"
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
